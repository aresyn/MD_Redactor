<Window x:Class="MDRedactor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MD Redactor"
        Width="1120"
        Height="720"
        MinWidth="860"
        MinHeight="520"
        Background="#F4F6F8">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16,12"
                Background="#FFFFFF"
                BorderBrush="#D6DCE2"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="MD Redactor"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#15202B" />
                    <TextBlock Text="{Binding CurrentFileTitle}"
                               Margin="0,2,0,0"
                               Foreground="#64748B" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Открыть" Command="{Binding OpenCommand}" />
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="EditorWebView" />
            <Border x:Name="StartupErrorPanel"
                    Visibility="Collapsed"
                    Background="#FFF7ED"
                    BorderBrush="#FDBA74"
                    BorderThickness="1"
                    Margin="24"
                    Padding="24"
                    MaxWidth="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Panel.ZIndex="1">
                <TextBlock x:Name="StartupErrorText"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="#7C2D12" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="16,8"
                Background="#FFFFFF"
                BorderBrush="#D6DCE2"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#334155" />
        </Border>
    </Grid>
</Window>
